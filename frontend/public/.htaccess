# ─────────────────────────────────────────────────────────
# Apache .htaccess — React SPA routing for Bluehost
# Place this file inside public_html/ alongside index.html
# ─────────────────────────────────────────────────────────

Options -MultiViews
RewriteEngine On

# If the request is for an existing file or directory, serve it directly
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Otherwise rewrite to index.html so React Router handles the route
RewriteRule ^ index.html [QSA,L]
